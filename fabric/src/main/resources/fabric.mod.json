{
	"schemaVersion": 1,
	"id": "fiwwarp",
	"version": "${version}",
	"name": "Fiw Warp",
	"description": "Lightweight, server-side teleport mod: homes, warps, warmups and cooldowns.",
	"authors": [
		"Fiw"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/fiw-warp",
		"sources": "https://github.com/Fi3w0/fiw-warp"
	},
	"license": "MIT",
	"icon": "assets/fiwwarp/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.fiw.warp.fabric.FiwWarpFabric",
				"adapter": "kotlin"
			}
		]
	},
	"depends": {
		"fabricloader": ">=0.19.0",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
